<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/signalNotifCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    android:layout_gravity="center_horizontal"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/signalLightGray"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/signalNotifIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            tools:src="@tools:sample/avatars"
            app:shapeAppearanceOverlay="@style/SignalNotifIconShape" />

        <TextView
            android:id="@+id/signalNotifTextSimple"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/signalBlack"
            android:textSize="15sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_reg"
            tools:text="Saved to"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:id="@+id/signalNotifTextHighlight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="@color/signalBlack"
            android:textSize="15sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_bold"
            tools:text="Men fashion casual outfits"
            xmlns:tools="http://schemas.android.com/tools" />

    </LinearLayout>

</androidx.cardview.widget.CardView>